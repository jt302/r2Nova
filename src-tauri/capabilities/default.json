{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "default",
  "description": "Default permissions for R2Nova",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "shell:allow-open"
  ]
}
